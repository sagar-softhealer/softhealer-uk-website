---
import themeSettings from '../content/settings/theme.json';

const primaryColor = themeSettings.primary_color || '#534ab7';
const secondaryColor = themeSettings.secondary_color || '#0ea5e9';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Softhealer UK - Odoo & Web Development Experts</title>
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global define:vars={{ primaryColor, secondaryColor }}>
	:root {
		--primary: var(--primaryColor);
		--primary-hover: var(--primaryColor);
		--primary-light: #eef2ff;
		--secondary: var(--secondaryColor);
		--secondary-hover: var(--secondaryColor);
		--dark: #0f172a;
		--dark-gray: #334155;
		--light: #f8fafc;
		--white: #ffffff;
		--text: #1e293b;
		--text-muted: #64748b;
		--border: #e2e8f0;
		--font-heading: 'Outfit', sans-serif;
		--font-body: 'Inter', sans-serif;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html, body {
		width: 100%;
		height: 100%;
		margin: 0;
		padding: 0;
	}
</style>
