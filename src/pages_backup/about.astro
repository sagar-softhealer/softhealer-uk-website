---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const aboutPage = await getEntry('pages', 'about');
const title = aboutPage?.data.title || "About Softhealer UK";
const description = aboutPage?.data.description || "Pioneering robust Odoo implementation, customization, and modern web application development.";
const storyTitle = aboutPage?.data.story_title || "Driving Business Automation Across the UK";
const storyBody = aboutPage?.data.story_body || "";
const stats = aboutPage?.data.stats || [];
const values = aboutPage?.data.values || [];
---

<Layout>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container header-container animate-fade-in">
      <span class="sub-title">Who We Are</span>
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
  </section>

  <!-- Company Story -->
  <section class="about-story">
    <div class="container story-grid">
      <div class="story-content animate-fade-in">
        <h2>{storyTitle}</h2>
        {storyBody.split('\n\n').map(p => p.trim() && <p>{p}</p>)}
      </div>
      <div class="story-stats">
        {stats.map((stat, idx) => (
          <div class={`stat-card animate-fade-in delay-${(idx + 1) * 100}`}>
            <span class="number"><span class="counter" data-target={stat.number}>0</span>+</span>
            <span class="label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="values">
    <div class="container">
      <div class="section-title animate-fade-in">
        <h2>Our Core Values</h2>
        <p>The principles that guide our team and define our relationships with clients.</p>
      </div>
      <div class="values-grid">
        {values.map((val, idx) => (
          <div class={`value-card animate-fade-in delay-${(idx + 1) * 100}`}>
            <div class="value-icon">{val.icon}</div>
            <h3>{val.title}</h3>
            <p>{val.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Counting Animation Script -->
  <script>
    const animateCounters = () => {
      const counters = document.querySelectorAll('.counter');
      const speed = 100; // lower number = faster animation

      counters.forEach(counter => {
        const updateCount = () => {
          const target = +counter.getAttribute('data-target')!;
          const count = +counter.textContent!;
          
          const increment = Math.ceil(target / speed);

          if (count < target) {
            counter.textContent = String(count + increment);
            setTimeout(updateCount, 15);
          } else {
            counter.textContent = String(target);
          }
        };
        
        updateCount();
      });
    };

    // Trigger animation using IntersectionObserver when stats section comes in view
    const statsSection = document.querySelector('.story-stats');
    if (statsSection) {
      const observer = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            animateCounters();
            observer.unobserve(entry.target); // Run animation only once
          }
        });
      }, { threshold: 0.1 });

      observer.observe(statsSection);
    }
  </script>
</Layout>

<style>
  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
    color: var(--white);
    padding: 80px 0;
    text-align: center;
  }

  .header-container {
    max-width: 800px;
  }

  .page-header h1 {
    font-size: 3rem;
    color: var(--white);
    margin-bottom: 16px;
    letter-spacing: -1px;
  }

  .page-header p {
    font-size: 1.2rem;
    color: #cbd5e1;
    line-height: 1.5;
  }

  .sub-title {
    color: var(--secondary);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 2px;
    display: inline-block;
    margin-bottom: 12px;
  }

  /* Story Section */
  .about-story {
    padding: 100px 0;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }

  @media (max-width: 992px) {
    .story-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .story-content h2 {
    font-size: 2.25rem;
    margin-bottom: 24px;
    line-height: 1.2;
  }

  .story-content p {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 20px;
  }

  .story-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .stat-card {
    background-color: var(--white);
    padding: 28px 20px;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    text-align: center;
    transition: var(--transition);
  }

  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary-light);
  }

  .stat-card .number {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--primary);
    display: block;
    margin-bottom: 4px;
    font-family: var(--font-heading);
  }

  .stat-card .label {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Values Section */
  .values {
    background-color: var(--white);
    padding: 100px 0;
    border-top: 1px solid var(--border);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  @media (max-width: 992px) {
    .values-grid {
      grid-template-columns: 1fr;
    }
  }

  .value-card {
    background-color: var(--light);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
    transition: var(--transition);
  }

  .value-card:hover {
    background-color: var(--white);
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .value-icon {
    font-size: 2rem;
    margin-bottom: 20px;
  }

  .value-card h3 {
    font-size: 1.25rem;
    margin-bottom: 12px;
  }

  .value-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>