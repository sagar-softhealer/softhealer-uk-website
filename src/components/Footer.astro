---
const currentYear = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="logo">Softhealer<span>UK</span></a>
      <p class="brand-desc">
        Empowering UK businesses with custom Odoo ERP integrations, bespoke web designs, and cutting-edge business automation pipelines.
      </p>
      <div class="social-links">
        <a href="#" aria-label="LinkedIn" class="social-icon">IN</a>
        <a href="#" aria-label="Twitter" class="social-icon">X</a>
        <a href="#" aria-label="GitHub" class="social-icon">GH</a>
      </div>
    </div>

    <div class="footer-links">
      <h3>Quick Links</h3>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-links">
      <h3>Odoo Services</h3>
      <ul>
        <li><a href="/services">Odoo Implementation</a></li>
        <li><a href="/services">Custom App Development</a></li>
        <li><a href="/services">eCommerce Customization</a></li>
        <li><a href="/services">API Integrations</a></li>
      </ul>
    </div>

    <div class="footer-contact">
      <h3>Get in Touch</h3>
      <p class="contact-item">
        <span class="icon">📍</span> London, United Kingdom
      </p>
      <p class="contact-item">
        <span class="icon">✉️</span> info@softhealer.co.uk
      </p>
      <p class="contact-item">
        <span class="icon">📞</span> +44 20 7946 0192
      </p>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-content">
      <p>&copy; {currentYear} Softhealer UK. All rights reserved.</p>
      <div class="footer-legal">
        <a href="#">Privacy Policy</a>
        <span class="divider">|</span>
        <a href="#">Terms & Conditions</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--dark);
    color: #94a3b8;
    padding: 72px 0 24px 0;
    border-top: 4px solid var(--primary);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }

  @media (max-width: 576px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .footer-brand .logo {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--white);
    letter-spacing: -0.5px;
    margin-bottom: 16px;
    display: inline-block;
  }

  .footer-brand .logo span {
    color: var(--secondary);
  }

  .brand-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 24px;
    color: #94a3b8;
  }

  .social-links {
    display: flex;
    gap: 12px;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: #1e293b;
    color: var(--white);
    font-size: 0.8rem;
    font-weight: 700;
    transition: var(--transition);
  }

  .social-icon:hover {
    background-color: var(--primary);
    transform: translateY(-2px);
  }

  .footer-links h3,
  .footer-contact h3 {
    color: var(--white);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 20px;
    font-family: var(--font-heading);
  }

  .footer-links ul {
    list-style: none;
  }

  .footer-links ul li {
    margin-bottom: 12px;
  }

  .footer-links ul li a {
    font-size: 0.95rem;
    transition: var(--transition);
  }

  .footer-links ul li a:hover {
    color: var(--secondary);
    padding-left: 4px;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
  }

  .contact-item .icon {
    font-size: 1.1rem;
  }

  .footer-bottom {
    border-top: 1px solid #1e293b;
    padding-top: 24px;
    margin-top: 24px;
  }

  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .footer-bottom-content {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }

  .footer-legal a {
    transition: var(--transition);
  }

  .footer-legal a:hover {
    color: var(--white);
  }

  .divider {
    margin: 0 8px;
    color: #334155;
  }
</style>
