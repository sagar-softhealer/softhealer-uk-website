---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container header-container">
      <span class="sub-title">Who We Are</span>
      <h1>About Softhealer UK</h1>
      <p>Pioneering robust Odoo implementation, customization, and modern web application development.</p>
    </div>
  </section>

  <!-- Company Story -->
  <section class="about-story">
    <div class="container story-grid">
      <div class="story-content">
        <h2>Driving Business Automation Across the UK</h2>
        <p>Softhealer UK is a premier technology consulting firm specializing in customized Enterprise Resource Planning (ERP) integrations and cloud-native web engineering. We help organizations streamline operations, eliminate data silos, and scale efficiently.</p>
        <p>Whether you are a growing mid-sized distributor in London, a manufacturing plant in Birmingham, or an e-commerce startup looking to automate order fulfillment, our local consultants analyze your workflows and design tailored solutions using Odoo's powerful suite.</p>
      </div>
      <div class="story-stats">
        <div class="stat-card">
          <span class="number">10+</span>
          <span class="label">Years of ERP Experience</span>
        </div>
        <div class="stat-card">
          <span class="number">150+</span>
          <span class="label">Custom Modules Created</span>
        </div>
        <div class="stat-card">
          <span class="number">99%</span>
          <span class="label">On-Time SLA Delivery</span>
        </div>
        <div class="stat-card">
          <span class="number">50+</span>
          <span class="label">Active Enterprise Clients</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values -->
  <section class="values">
    <div class="container">
      <div class="section-title">
        <h2>Our Core Values</h2>
        <p>The principles that guide our team and define our relationships with clients.</p>
      </div>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-icon">🤝</div>
          <h3>Customer First</h3>
          <p>We work as an extension of your internal team, understanding your specific business model and pain points before writing a single line of code.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">💎</div>
          <h3>Uncompromised Quality</h3>
          <p>We write clean, documented, and fully tested Odoo modules and web code that follow international coding standards and pass strict security audits.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">🚀</div>
          <h3>Continuous Innovation</h3>
          <p>We stay at the forefront of modern web engineering (like Astro) and artificial intelligence workflows (like MCP and automated content drafting).</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
    color: var(--white);
    padding: 80px 0;
    text-align: center;
  }

  .header-container {
    max-width: 800px;
  }

  .page-header h1 {
    font-size: 3rem;
    color: var(--white);
    margin-bottom: 16px;
    letter-spacing: -1px;
  }

  .page-header p {
    font-size: 1.2rem;
    color: #cbd5e1;
    line-height: 1.5;
  }

  .sub-title {
    color: var(--secondary);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 2px;
    display: inline-block;
    margin-bottom: 12px;
  }

  /* Story Section */
  .about-story {
    padding: 100px 0;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }

  @media (max-width: 992px) {
    .story-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  .story-content h2 {
    font-size: 2.25rem;
    margin-bottom: 24px;
    line-height: 1.2;
  }

  .story-content p {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 20px;
  }

  .story-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .stat-card {
    background-color: var(--white);
    padding: 28px 20px;
    border-radius: 12px;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-sm);
    text-align: center;
    transition: var(--transition);
  }

  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary-light);
  }

  .stat-card .number {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--primary);
    display: block;
    margin-bottom: 4px;
    font-family: var(--font-heading);
  }

  .stat-card .label {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Values Section */
  .values {
    background-color: var(--white);
    padding: 100px 0;
    border-top: 1px solid var(--border);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  @media (max-width: 992px) {
    .values-grid {
      grid-template-columns: 1fr;
    }
  }

  .value-card {
    background-color: var(--light);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
    transition: var(--transition);
  }

  .value-card:hover {
    background-color: var(--white);
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .value-icon {
    font-size: 2rem;
    margin-bottom: 20px;
  }

  .value-card h3 {
    font-size: 1.25rem;
    margin-bottom: 12px;
  }

  .value-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>