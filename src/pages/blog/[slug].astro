---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blogs');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout>
  <!-- Blog Article Header -->
  <section class="blog-header">
    <div class="container header-container animate-fade-in">
      <a href="/blog" class="back-link">&larr; Back to all blogs</a>
      <div class="post-meta">
        <span class="author">👤 {post.data.author}</span>
        <span class="date">📅 {new Date(post.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
      </div>
      <h1>{post.data.title}</h1>
      <p class="description">{post.data.description}</p>
    </div>
  </section>

  <!-- Blog Article Body -->
  <section class="blog-content-section">
    <div class="container content-container">
      {post.data.image && (
        <div class="post-cover animate-fade-in delay-100">
          <img src={post.data.image} alt={post.data.title} onerror="this.style.display='none'" />
        </div>
      )}
      <div class="prose animate-fade-in delay-200">
        <Content />
      </div>
    </div>
  </section>
</Layout>

<style>
  .blog-header {
    background-color: var(--dark);
    color: var(--white);
    padding: 80px 0;
    text-align: left;
  }

  .blog-header .header-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    color: var(--secondary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
    display: inline-block;
    margin-bottom: 24px;
    transition: var(--transition);
  }

  .back-link:hover {
    transform: translateX(-4px);
  }

  .post-meta {
    display: flex;
    gap: 20px;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 16px;
  }

  .blog-header h1 {
    color: var(--white);
    font-size: 2.5rem;
    line-height: 1.25;
    margin-bottom: 16px;
  }

  .blog-header .description {
    font-size: 1.15rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
  }

  .blog-content-section {
    padding: 80px 0;
    background-color: var(--white);
  }

  .content-container {
    max-width: 800px;
    margin: 0 auto;
  }

  .post-cover {
    width: 100%;
    max-height: 450px;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 48px;
    box-shadow: var(--shadow-md);
  }

  .post-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .prose {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--dark);
  }

  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    margin-top: 40px;
    margin-bottom: 20px;
    color: var(--dark);
  }

  .prose :global(p) {
    margin-bottom: 24px;
  }

  .prose :global(ul) {
    margin-bottom: 24px;
    padding-left: 20px;
  }

  .prose :global(li) {
    margin-bottom: 8px;
  }

  .prose :global(strong) {
    color: var(--primary);
  }
</style>
