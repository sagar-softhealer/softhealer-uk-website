---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map(page => ({
    params: { slug: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);

// Retrieve modular page builder sections if configured
const sections = page.data.sections || [];
---

<Layout>
  {sections.length > 0 ? (
    // Dynamic Page Builder Sections
    sections.map((section) => {
      if (section._type === 'hero') {
        return (
          <section class="hero-block">
            <div class="container hero-block-container">
              <h1 class="animate-fade-in">{section.title}</h1>
              <p class="animate-fade-in delay-100">{section.description}</p>
              {section.button_text && (
                <a href={section.button_url || "/contact"} class="btn btn-primary animate-fade-in delay-200">
                  {section.button_text}
                </a>
              )}
            </div>
          </section>
        );
      }

      if (section._type === 'features') {
        return (
          <section class="features-block">
            <div class="container">
              <div class="section-title animate-fade-in">
                <h2>{section.title}</h2>
              </div>
              <div class="features-block-grid">
                {section.items?.map((item, index) => (
                  <div class={`feature-block-card animate-fade-in delay-${(index % 3 + 1) * 100}`}>
                    <span class="icon">{item.icon || "💼"}</span>
                    <h3>{item.title}</h3>
                    <p>{item.description}</p>
                  </div>
                ))}
              </div>
            </div>
          </section>
        );
      }

      if (section._type === 'process') {
        return (
          <section class="process-block">
            <div class="container">
              <div class="section-title animate-fade-in">
                <h2>{section.title}</h2>
              </div>
              <div class="process-block-grid">
                {section.steps?.map((step, index) => (
                  <div class={`process-block-step animate-fade-in delay-${(index % 4 + 1) * 100}`}>
                    <div class="step-num">{step.step_num || `0${index + 1}`}</div>
                    <h3>{step.title}</h3>
                    <p>{step.description}</p>
                  </div>
                ))}
              </div>
            </div>
          </section>
        );
      }

      if (section._type === 'cta') {
        return (
          <section class="cta-block">
            <div class="container cta-block-container">
              <h2>{section.title}</h2>
              <p>{section.description}</p>
              {section.button_text && (
                <a href={section.button_url || "/contact"} class="btn btn-secondary">
                  {section.button_text}
                </a>
              )}
            </div>
          </section>
        );
      }

      return null;
    })
  ) : (
    // Default Static Markdown Article Page
    <>
      <section class="page-header">
        <div class="container header-container">
          <h1 class="animate-fade-in">{page.data.title}</h1>
          {page.data.description && <p class="animate-fade-in delay-100">{page.data.description}</p>}
        </div>
      </section>

      <section class="page-content">
        <div class="container animate-fade-in delay-200">
          <article class="prose">
            <Content />
          </article>
        </div>
      </section>
    </>
  )}
</Layout>

<style>
  /* Default Page Styles */
  .page-content {
    padding: 80px 0;
    background-color: var(--white);
  }

  .prose {
    max-width: 800px;
    margin: 0 auto;
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--dark);
  }

  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    margin-top: 32px;
    margin-bottom: 16px;
    color: var(--dark);
  }

  .prose :global(p) {
    margin-bottom: 20px;
  }

  /* Page Builder blocks */
  
  /* Hero Block */
  .hero-block {
    padding: 120px 0;
    background: linear-gradient(135deg, var(--primary-light) 0%, var(--white) 100%);
    text-align: center;
    border-bottom: 1px solid var(--border);
  }

  .hero-block-container {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .hero-block h1 {
    font-size: 3rem;
    line-height: 1.15;
    letter-spacing: -1px;
    color: var(--dark);
  }

  .hero-block p {
    font-size: 1.25rem;
    color: var(--text-muted);
  }

  /* Features Grid Block */
  .features-block {
    padding: 100px 0;
    background-color: var(--white);
  }

  .section-title {
    text-align: center;
    margin-bottom: 50px;
  }

  .section-title h2 {
    font-size: 2.25rem;
    color: var(--dark);
  }

  .features-block-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  @media (max-width: 992px) {
    .features-block-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 576px) {
    .features-block-grid {
      grid-template-columns: 1fr;
    }
  }

  .feature-block-card {
    background-color: var(--light);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
    transition: var(--transition);
  }

  .feature-block-card:hover {
    transform: translateY(-6px);
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .feature-block-card .icon {
    font-size: 2.5rem;
    display: inline-block;
    margin-bottom: 16px;
  }

  .feature-block-card h3 {
    font-size: 1.25rem;
    margin-bottom: 12px;
  }

  .feature-block-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Process Steps Block */
  .process-block {
    padding: 100px 0;
    background-color: var(--light);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .process-block-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  @media (max-width: 992px) {
    .process-block-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 576px) {
    .process-block-grid {
      grid-template-columns: 1fr;
    }
  }

  .process-block-step {
    background-color: var(--white);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px 24px;
    transition: var(--transition);
  }

  .process-block-step:hover {
    transform: translateY(-6px);
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .process-block-step .step-num {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
    color: rgba(83, 74, 183, 0.15);
    line-height: 1;
    margin-bottom: 16px;
  }

  .process-block-step h3 {
    font-size: 1.2rem;
    margin-bottom: 12px;
  }

  .process-block-step p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Call to Action Block */
  .cta-block {
    padding: 80px 0;
    background-color: var(--primary);
    color: var(--white);
    text-align: center;
  }

  .cta-block-container {
    max-width: 700px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .cta-block h2 {
    color: var(--white);
    font-size: 2.25rem;
  }

  .cta-block p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.15rem;
  }
</style>
