---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const servicesPage = await getEntry('pages', 'services');
const title = servicesPage?.data.title || "Our Professional Services";
const description = servicesPage?.data.description || "Tailored enterprise software, modern web portals, and system integrations designed to fuel your business growth.";
const services = servicesPage?.data.services || [];
---

<Layout>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container header-container animate-fade-in">
      <span class="sub-title">What We Do</span>
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
  </section>

  <!-- Service Catalog Grid -->
  <section class="services-catalog">
    <div class="container">
      <div class="services-grid">
        {services.map((service, idx) => (
          <div class={`service-card animate-fade-in delay-${((idx % 3) + 1) * 100}`}>
            <span class="icon">{service.icon}</span>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
            {service.features && (
              <ul class="bullet-list">
                {service.features.map((feat) => (
                  <li>{feat}</li>
                ))}
              </ul>
            )}
          </div>
        ))}

        <!-- Consultation Card -->
        <div class="service-card consultation-card animate-fade-in delay-300">
          <h3>Need a custom solution?</h3>
          <p>Get a direct consultation with one of our principal architects to design a bespoke software stack for your business.</p>
          <a href="/contact" class="btn btn-secondary">Get a Custom Quote</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Page Header */
  .page-header {
    background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
    color: var(--white);
    padding: 80px 0;
    text-align: center;
  }

  .header-container {
    max-width: 800px;
  }

  .page-header h1 {
    font-size: 3rem;
    color: var(--white);
    margin-bottom: 16px;
    letter-spacing: -1px;
  }

  .page-header p {
    font-size: 1.2rem;
    color: #cbd5e1;
    line-height: 1.5;
  }

  .sub-title {
    color: var(--secondary);
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 2px;
    display: inline-block;
    margin-bottom: 12px;
  }

  /* Catalog Grid */
  .services-catalog {
    padding: 100px 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  @media (max-width: 992px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  .service-card {
    background-color: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary-light);
  }

  .service-card .icon {
    font-size: 2.5rem;
    margin-bottom: 24px;
    display: inline-block;
  }

  .service-card h3 {
    font-size: 1.35rem;
    margin-bottom: 16px;
  }

  .service-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .bullet-list {
    list-style: none;
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bullet-list li {
    font-size: 0.9rem;
    color: var(--text);
    position: relative;
    padding-left: 20px;
  }

  .bullet-list li::before {
    content: "•";
    color: var(--primary);
    font-size: 1.25rem;
    position: absolute;
    left: 0;
    top: -2px;
  }

  /* Consultation Card specific styles */
  .consultation-card {
    background-color: var(--primary);
    color: var(--white);
    border: none;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .consultation-card h3 {
    color: var(--white);
    font-size: 1.6rem;
    margin-bottom: 16px;
  }

  .consultation-card p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1rem;
    margin-bottom: 28px;
  }

  .consultation-card .btn {
    width: 100%;
  }
</style>